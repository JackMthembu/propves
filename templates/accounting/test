{% extends "base.html" %}

{% block content %}
<main id="main" class="main">
    <div class="pagetitle">
        <h1>Budget Management</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ url_for('main.dashboard') }}">Dashboard</a></li>
                <li class="breadcrumb-item active">Budget</li>
            </ol>
        </nav>
    </div>

    <!-- Budget Table Section -->
    <section class="section">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Budget Planning</h5>

                <!-- Filters -->
                <div class="row mb-3">
                    <div class="col-md-4">
                        <select class="form-select" id="propertyFilter" name="property_id">
                            <option value="">Select Property</option>
                            {% for property in properties %}
                                <option value="{{ property.id }}" {% if request.args.get('property_id')|int == property.id %}selected{% endif %}>
                                    {{ property.title }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-4">
                        <select class="form-select" id="budgetTypeFilter" name="budget_type">
                            <option value="">All Budget Types</option>
                            <option value="renovation" {% if request.args.get('budget_type') == 'renovation' %}selected{% endif %}>Renovation Budget</option>
                            <option value="maintenance" {% if request.args.get('budget_type') == 'maintenance' %}selected{% endif %}>Maintenance Budget</option>
                            <option value="development" {% if request.args.get('budget_type') == 'development' %}selected{% endif %}>Development Budget</option>
                            <option value="other" {% if request.args.get('budget_type') == 'other' %}selected{% endif %}>Other</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-outline-secondary" id="applyFilters">
                            <i class="bi bi-funnel"></i> Apply Filters
                        </button>
                    </div>
                </div>

                <!-- Table -->
                <div class="table-responsive">
                    <table class="table datatable">
                        <thead>
                            <tr>
                                <th>Property</th>
                                <th>Budget Type</th>
                                <th>Description</th>
                                <th>Budget Amount</th>
                                <th>Actual Amount</th>
                                <th>Variance</th>
                                <th>Last Updated</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="budgetBody">
                            {% if budgets %}
                                {% for budget in budgets %}
                                <tr data-id="{{ budget.property_id }}" class="editable-row">
                                    <td class="editable" data-field="property">
                                        <select class="form-control form-control-sm property-selector" data-budget-id="{{ budget.id }}">
                                            <option value="portfolio">Portfolio (Fixed Amount)</option>
                                            <option value="all">All Properties (Split Equally)</option>
                                            {% for property in properties %}
                                            <option value="{{ property.id }}" {% if property.id == budget.property_id %}selected{% endif %}>
                                                {{ property.title }}
                                            </option>
                                            {% endfor %}
                                        </select>
                                    </td>
                                    <td class="editable" data-field="budget_type">
                                        <select class="form-control form-control-sm" onchange="updateBudget(this)">
                                            <option value="renovation" {% if budget.budget_type == 'renovation' %}selected{% endif %}>Renovation Budget</option>
                                            <option value="maintenance" {% if budget.budget_type == 'maintenance' %}selected{% endif %}>Maintenance Budget</option>
                                            <option value="development" {% if budget.budget_type == 'development' %}selected{% endif %}>Development Budget</option>
                                            <option value="other" {% if budget.budget_type == 'other' %}selected{% endif %}>Other</option>
                                        </select>
                                    </td>
                                    <td class="editable" data-field="budget_description">
                                        <input type="text" class="form-control form-control-sm" 
                                               value="{{ budget.budget_description }}"
                                               onchange="updateBudget(this)">
                                    </td>
                                    <td class="editable" data-field="budget_amount">
                                        <input type="number" step="0.01" class="form-control form-control-sm" 
                                               value="{{ '%.2f'|format(budget.budget_amount) }}"
                                               onchange="updateBudget(this)">
                                    </td>
                                    <td class="editable" data-field="actual_amount">
                                        <input type="number" step="0.01" class="form-control form-control-sm" 
                                               value="{{ '%.2f'|format(budget.actual_amount) }}"
                                               onchange="updateBudget(this)">
                                    </td>
                                    <td class="variance">
                                        {{ '%.2f'|format(budget.budget_amount - budget.actual_amount) }}
                                    </td>
                                    <td>
                                        {{ budget.date_updated.strftime('%Y-%m-%d') }}
                                    </td>
                                    <td>
                                        <div class="btn-group">
                                            <button class="btn btn-sm btn-success save-row" onclick="saveBudget(this)">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger delete-row" onclick="deleteBudget(this)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            {% else %}
                                <tr class="editable-row">
                                    <td>
                                        <select class="form-control form-control-sm property-selector">
                                            <option value="portfolio">Portfolio (Fixed Amount)</option>
                                            <option value="all">All Properties (Split Equally)</option>
                                            {% for property in properties %}
                                            <option value="{{ property.id }}">{{ property.title }}</option>
                                            {% endfor %}
                                        </select>
                                    </td>
                                    <td class="editable" data-field="budget_type">
                                        <select class="form-control form-control-sm">
                                            <option value="renovation">Renovation Budget</option>
                                            <option value="maintenance">Maintenance Budget</option>
                                            <option value="development">Development Budget</option>
                                            <option value="other">Other</option>
                                        </select>
                                    </td>
                                    <td class="editable" data-field="description">
                                        <input type="text" class="form-control form-control-sm" value="">
                                    </td>
                                    <td class="editable" data-field="budget_amount">
                                        <input type="number" step="0.01" class="form-control form-control-sm" 
                                               value="0.00">
                                    </td>
                                    <td class="editable" data-field="actual_amount">
                                        <input type="number" step="0.01" class="form-control form-control-sm" 
                                               value="0.00">
                                    </td>
                                    <td class="variance">0.00</td>
                                    <td>{{ today.strftime('%Y-%m-%d') }}</td>
                                    <td>
                                        <div class="btn-group">
                                            <button class="btn btn-sm btn-success save-row" onclick="saveBudget(this)">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger delete-row" onclick="deleteBudget(this)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>

                <!-- Add New Budget Button -->
                <div class="mt-3">
                    <button class="btn btn-primary" onclick="addNewBudgetRow()">
                        <i class="bi bi-plus-circle"></i> Add New Budget
                    </button>
                </div>

                <!-- Pagination -->
                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center">
                        {% if pagination.has_prev %}
                            <li class="page-item">
                                <a class="page-link" href="{{ url_for('accounting_routes.get_budget', page=pagination.prev_num, property_id=request.args.get('property_id'), budget_type=request.args.get('budget_type')) }}">Previous</a>
                            </li>
                        {% endif %}
                        
                        {% for page_num in pagination.iter_pages() %}
                            <li class="page-item {% if page_num == pagination.page %}active{% endif %}">
                                <a class="page-link" href="{{ url_for('accounting_routes.get_budget', page=page_num, property_id=request.args.get('property_id'), budget_type=request.args.get('budget_type')) }}">{{ page_num }}</a>
                            </li>
                        {% endfor %}
                        
                        {% if pagination.has_next %}
                            <li class="page-item">
                                <a class="page-link" href="{{ url_for('accounting_routes.get_budget', page=pagination.next_num, property_id=request.args.get('property_id'), budget_type=request.args.get('budget_type')) }}">Next</a>
                            </li>
                        {% endif %}
                    </ul>
                </nav>
            </div>
        </div>
    </section>
</main>
{% endblock %}

{% block scripts %}
<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Budget Manager -->
<script src="{{ url_for('static', filename='js/budget.js') }}"></script>
{% endblock %} 